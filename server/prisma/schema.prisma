// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Transaction {
  id          Int      @id @default(autoincrement())
  amount      Float
  description String
  category    String
  type        String
  createdAt   DateTime @default(now())
}